generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(uuid()) @db.Uuid
  email        String?        @unique
  passwordHash String         @map("password_hash")
  emailVerified Boolean       @default(false) @map("email_verified")
  emailVerifiedAt DateTime?   @map("email_verified_at")
  verificationTokenHash String? @map("verification_token_hash")
  passwordResetTokenHash String? @map("password_reset_token_hash")
  passwordResetExpiresAt DateTime? @map("password_reset_expires_at")
  googleSub    String?        @unique @map("google_sub")
  username     String?        @map("username")
  displayName  String?        @map("display_name")
  avatarUrl    String?        @map("avatar_url")
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  revision     String         @default("rev-0") @map("revision")
  refreshTokens RefreshToken[]
  serverChanges ServerChange[]
  syncDeviceStates SyncDeviceState[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @map("token_hash")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}


model Task {
  id             String   @id @db.Uuid
  projectId      String?  @map("projectid") @db.Uuid
  workspaceId    String?  @map("workspace_id") @db.Uuid
  title          String
  description    String
  statusId       String   @map("statusid")
  priority       String
  assigneeUserId String?  @map("assigneeuserid") @db.Uuid
  createdByUserId String  @map("createdbyuserid") @db.Uuid
  updatedAt      DateTime @map("updatedat")
  revision       String
  deletedAt      DateTime? @map("deletedat")

  @@map("tasks")
}

model Comment {
  id             String   @id @db.Uuid
  taskId         String   @map("taskid") @db.Uuid
  body           String
  createdByUserId String  @map("createdbyuserid") @db.Uuid
  createdAt      DateTime @map("createdat")
  updatedAt      DateTime @map("updatedat")
  revision       String
  deletedAt      DateTime? @map("deletedat")

  @@map("comments")
}

model TaskEvent {
  id             String   @id @db.Uuid
  taskId         String   @map("taskid") @db.Uuid
  type           String
  payload        String
  createdAt      DateTime @map("createdat")
  createdByUserId String  @map("createdbyuserid") @db.Uuid
  scopeKey       String   @map("scopekey")
  revision       String
  deletedAt      DateTime? @map("deletedat")

  @@index([taskId])
  @@index([scopeKey])
  @@map("task_events")
}

model WorkspaceMember {
  id          String   @id @db.Uuid
  workspaceId String   @map("workspace_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  role        String
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  revision    String

  @@index([workspaceId])
  @@index([userId])
  @@unique([workspaceId, userId])
  @@map("workspace_members")
}

model WorkspaceInvite {
  id           String   @id @default(uuid()) @db.Uuid
  workspaceId  String   @map("workspace_id") @db.Uuid
  workspaceLabel String @map("workspace_label")
  email        String
  token        String   @unique
  role         String
  invitedById  String   @map("invited_by_id") @db.Uuid
  status       String
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  expiresAt    DateTime @map("expires_at")
  acceptedAt   DateTime? @map("accepted_at")
  acceptedById String?  @map("accepted_by_id") @db.Uuid

  @@index([workspaceId])
  @@index([email])
  @@map("workspace_invites")
}

model Workspace {
  id        String   @id @default(uuid()) @db.Uuid
  label     String
  kind      String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("workspaces")
}

model OpDedup {
  opId      String   @id @map("opid")
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  @@map("op_dedup")
}

model ServerChange {
  id         BigInt   @id @default(autoincrement())
  userId     String   @map("user_id") @db.Uuid
  entityType String   @map("entitytype")
  entityId   String   @map("entityid")
  opType     String   @map("optype")
  payload    Json
  revision   String
  updatedAt  DateTime @map("updatedat")
  createdAt  DateTime @default(now()) @map("createdat")

  user User @relation(fields: [userId], references: [id])

  @@index([userId, id])
  @@map("server_changes")
}

model SyncDeviceState {
  id         String   @id @default(cuid())
  userId     String   @map("user_id") @db.Uuid
  deviceId   String   @map("device_id")
  lastCursor BigInt   @default(0) @map("last_cursor")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, deviceId])
  @@index([userId, lastCursor])
  @@map("sync_device_state")
}
